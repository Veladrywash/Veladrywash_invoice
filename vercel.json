 {
   "rewrites": [
     { 
       "source": "/((?!assets/|sw.js|manifest.webmanifest|pwa-|logo).*)", 
       "destination": "/index.html" 
     }
   ],
  "headers": [
    {
      "source": "/service-worker.js",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache, no-store, must-revalidate"
        }
      ]
    }
  ]
}
